{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mapper Viewer",
  "version": "0.1.0",
  "identifier": "edu.vanderbilt.gift.mapper-viewer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Mapper",
        "width": 1500,
        "height": 950,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "category": "DeveloperTool",
    "icon": ["icons/icon.ico", "icons/icon.png"]
  }
}
